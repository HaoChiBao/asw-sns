# AWS region (used by CDK deploy only — dashboard does not need AWS credentials)
AWS_REGION=us-east-2

# Dashboard server port
PORT=8080

# Read-only API (deploy CDK stack, then paste ReaderApiUrl output here)
READER_API_URL=https://YOUR_API_ID.execute-api.us-east-2.amazonaws.com
# Optional — must match READER_API_KEY on the Reader Lambda if you set one in CDK
# READER_API_KEY=

# ── Dashboard auth ──
DASHBOARD_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-random-secret
# SESSION_MAX_DAYS=30

# CDK only — phone numbers listed by the read API (comma-separated)
# PHONE_NUMBERS=+12362051147,+18257730586
