{
  "name": "asw-sns",
  "version": "1.0.0",
  "private": true,
  "description": "AWS inbound SMS pipeline: End User Messaging → SNS → Lambda → DynamoDB",
  "workspaces": [
    "cdk",
    "lambda",
    "api"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "deploy": "npm run deploy --workspace=cdk",
    "diff": "npm run diff --workspace=cdk",
    "synth": "npm run synth --workspace=cdk",
    "test:local": "npm run test:local --workspace=lambda --",
    "dashboard": "npm run dev --workspace=api",
    "deploy:dashboard": "vercel --cwd api",
    "deploy:dashboard:prod": "vercel --cwd api --prod"
  },
  "engines": {
    "node": ">=20"
  }
}
