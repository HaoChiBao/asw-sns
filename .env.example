# AWS region (phone pool and DynamoDB are in us-east-2)
AWS_REGION=us-east-2

# DynamoDB table for inbound SMS
DYNAMODB_TABLE_NAME=InboundSmsMessages

# Phone pool ID for send + pool overview
POOL_ID=pool-beaed95ac15e49bd9dfcc1e62689236d

# Dashboard server port
PORT=3000

# Optional: override for local testing when not using deployed resources
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
